# Makefile — test entry-point para TODO(identity.name)
#
# Harness mínimo emitido por pos (C3). Targets universales:
#   make test          # alias de test-unit
#   make test-unit     # unit tests
#   make test-coverage # unit tests con coverage
#   make clean         # limpia artefactos de test/coverage
#
# Nota: C3 no emite package.json/pyproject.toml. La instalación del stack
# queda pendiente de fase posterior. Los targets invocan binarios asumiendo
# que el stack está instalado localmente.

.PHONY: test test-unit test-coverage clean

test: test-unit

test-unit:
	npx vitest run

test-coverage:
	npx vitest run --coverage


clean:
	rm -rf coverage/ .pytest_cache/ .vitest_cache/ .coverage
