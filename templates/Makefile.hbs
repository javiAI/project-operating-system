{{!-- templates/Makefile.hbs — universal test entry-point (C3) --}}
# Makefile — test entry-point para {{answers.identity.name}}
#
# Harness minimo emitido por pos (C3). Targets universales:
#   make test          # alias de test-unit
#   make test-unit     # unit tests
#   make test-coverage # unit tests con coverage
{{#if (eq answers.stack.language "typescript")}}
#   make test-e2e      # e2e placeholder (ver tests/README.md)
{{/if}}
#   make clean         # limpia artefactos de test/coverage
#
# Nota: C3 no emite package.json/pyproject.toml. La instalacion del stack
# queda pendiente de fase posterior. Los targets invocan binarios asumiendo
# que el stack esta instalado localmente.

.PHONY: test test-unit test-coverage{{#if (eq answers.stack.language "typescript")}} test-e2e{{/if}} clean

test: test-unit

{{#if (eq answers.stack.language "typescript")}}
test-unit:
	npx vitest run

test-coverage:
	npx vitest run --coverage

test-e2e:
	@echo "E2E: ver tests/README.md para configurar el framework elegido."
{{/if}}
{{#if (eq answers.stack.language "python")}}
test-unit:
	python3 -m pytest

test-coverage:
	python3 -m pytest --cov --cov-report=term-missing
{{/if}}

clean:
	rm -rf coverage/ .pytest_cache/ .vitest_cache/ .coverage
