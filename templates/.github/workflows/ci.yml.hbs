{{!-- templates/.github/workflows/ci.yml.hbs — CI workflow for the generated project (C4). --}}
{{!-- Runtime versions hardcoded in C4; see .claude/rules/generator.md § Deferrals. --}}
name: ci

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

concurrency:
  group: $\{{ github.workflow }}-$\{{ github.ref }}
  cancel-in-progress: true

jobs:
  unit:
    name: unit
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@692973e3d937129bcbf40652eb9f2f61becf3332 # v4.1.7

{{#if (eq answers.stack.language "typescript")}}
      - name: Setup Node
        uses: actions/setup-node@1e60f620b9541d16bece96c5465dc8ee9832be0b # v4.0.3
        with:
          node-version: "20.17.0"

      - name: Install test deps
        run: npm install --no-save vitest@3.0.5 @vitest/coverage-v8@3.0.5

{{/if}}
{{#if (eq answers.stack.language "python")}}
      - name: Setup Python
        uses: actions/setup-python@0b93645e9fea7318ecaed2b359559ac225c90a2b # v5.3.0
        with:
          python-version: "3.11"

      - name: Install test deps
        run: python -m pip install --upgrade pip && pip install pytest pytest-cov

{{/if}}
      - name: Unit tests
        run: make test-unit

      - name: Unit tests (coverage)
        run: make test-coverage
