{
  "$schema": "https://claude.com/schemas/settings.local.json",
  "permissions": {
    "allow": [
      "Bash(git init:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull origin main --ff-only)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(ls:*)",
      "Bash(mkdir -p .claude/*)",
      "Bash(mkdir -p docs)",
      "Bash(mkdir -p generator/*)",
      "Bash(mkdir -p templates/*)",
      "Bash(mkdir -p hooks)",
      "Bash(mkdir -p skills/*)",
      "Bash(mkdir -p agents)",
      "Bash(mkdir -p bin)",
      "Bash(touch .claude/branch-approvals/*.approved)",
      "Bash(touch .claude/logs/.gitkeep)",
      "Bash(touch .claude/patterns/.gitkeep)",
      "Bash(touch .claude/invariants/.gitkeep)",
      "Bash(touch .claude/anti-patterns/.gitkeep)",
      "Bash(touch .claude/branch-approvals/.gitkeep)",
      "Bash(npx tsx:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python3 -m mypy:*)",
      "Bash(python3 -m ruff:*)",
      "Bash(./bin/pos-selftest.sh:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh api:*)",
      "Bash(gh repo view:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force-with-lease origin main:*)",
      "Bash(git reset --hard origin/main)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(npm install:*)",
      "Bash(pip install:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/session-start.py",
            "timeout": 5000,
            "statusMessage": "Loading pos snapshot...",
            "_note": "Fase D entrega el script. Hasta entonces este hook es no-op al faltar el archivo."
          }
        ]
      }
    ],
    "UserPromptSubmit": [],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/pre-branch-gate.py",
            "timeout": 5000,
            "statusMessage": "Branch gate (Fase -1)...",
            "_note": "Entregado en Fase D. Bloquea git checkout -b / git switch -c sin marker."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/pre-write-guard.py",
            "timeout": 3000,
            "_note": "Entregado en Fase D. Enforza test-pair + pattern injection."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/post-action.py",
            "timeout": 5000,
            "_note": "Entregado en Fase D. Post-merge dispara /pos:compound si touched_paths."
          }
        ]
      }
    ],
    "PostToolUseFailure": [],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/pre-compact.py",
            "timeout": 10000,
            "_note": "Entregado en Fase D. Persiste decisiones in-flight antes de compactar."
          }
        ]
      }
    ],
    "SubagentStop": [],
    "InstructionsLoaded": [],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/stop-policy-check.py",
            "timeout": 5000,
            "_note": "Entregado en Fase D. Valida policy.yaml vs skill logs del turno."
          }
        ]
      }
    ]
  },
  "claudeMdExcludes": [
    "master_repo_blueprint.md",
    ".claude/worktrees/**",
    "tmp/**",
    "generated/**"
  ]
}
